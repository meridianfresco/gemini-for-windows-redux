{
  "name": "gemini-for-windows-redux",
  "private": true,
  "version": "1.0.0",
  "description": "Google Gemini for Windows Redux - A sleek, native & frameless desktop client for Google Gemini.",
  "main": "main.js",
  "type": "commonjs",
  "homepage": "https://github.com/meridianfresco/gemini-for-windows-redux",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/meridianfresco/gemini-for-windows-redux.git"
  },
  "bugs": {
    "url": "https://github.com/meridianfresco/gemini-for-windows-redux/issues"
  },
  "keywords": [
    "gemini",
    "gemini-app",
    "gemini-desktop",
    "gemini-for-windows",
    "gemini-for-windows-redux",
    "gemini-on-pc",
    "electron"
  ],
  "author": "meridianfresco (https://github.com/meridianfresco)",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "start": "electron .",
    "build": "vite build",
    "build:win": "electron-builder --win",
    "dev:react": "vite --port=3000 --host=0.0.0.0"
  },
  "build": {
    "appId": "com.gemini.customwrapper",
    "productName": "Gemini Desktop",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2"
  }
}
